{
  "title": "Scraping Platform — Overview",
  "uid":   "scraping-overview",
  "tags":  ["scraping", "platform"],
  "time":  { "from": "now-1h", "to": "now" },
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "title": "API Request Rate (req/s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [{
        "expr": "rate(http_requests_total{job=\"scraping_backend\"}[1m])",
        "legendFormat": "{{method}} {{handler}} {{status}}"
      }],
      "fieldConfig": {
        "defaults": { "unit": "reqps", "color": { "mode": "palette-classic" } }
      }
    },
    {
      "id": 2,
      "title": "API P95 Latency (ms)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [{
        "expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket{job=\"scraping_backend\"}[5m])) * 1000",
        "legendFormat": "p95 {{handler}}"
      }],
      "fieldConfig": {
        "defaults": { "unit": "ms", "thresholds": {
          "steps": [
            { "color": "green",  "value": 0   },
            { "color": "yellow", "value": 500 },
            { "color": "red",    "value": 1000 }
          ]
        }}
      }
    },
    {
      "id": 3,
      "title": "API Error Rate (%)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 8 },
      "targets": [{
        "expr": "100 * rate(http_requests_total{job=\"scraping_backend\",status=~\"5..\"}[5m]) / rate(http_requests_total{job=\"scraping_backend\"}[5m])"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "steps": [
              { "color": "green",  "value": 0   },
              { "color": "yellow", "value": 1   },
              { "color": "red",    "value": 5   }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "title": "Celery Active Tasks",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 8 },
      "targets": [{
        "expr": "flower_worker_tasks_active{job=\"celery_workers\"}"
      }],
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green",  "value": 0  },
              { "color": "yellow", "value": 10 },
              { "color": "red",    "value": 50 }
            ]
          }
        }
      }
    },
    {
      "id": 5,
      "title": "Celery Failed Tasks (5m rate)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 8 },
      "targets": [{
        "expr": "rate(flower_worker_tasks_failed_total[5m])"
      }],
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "red",   "value": 1 }
            ]
          }
        }
      }
    },
    {
      "id": 6,
      "title": "Scraping Success Rate (%)",
      "type": "gauge",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 8 },
      "targets": [{
        "expr": "100 * rate(flower_worker_tasks_succeeded_total[1h]) / (rate(flower_worker_tasks_succeeded_total[1h]) + rate(flower_worker_tasks_failed_total[1h]) + 0.001)"
      }],
      "fieldConfig": {
        "defaults": { "unit": "percent", "min": 0, "max": 100,
          "thresholds": {
            "steps": [
              { "color": "red",    "value": 0  },
              { "color": "yellow", "value": 80 },
              { "color": "green",  "value": 95 }
            ]
          }
        }
      }
    },
    {
      "id": 7,
      "title": "Request Rate by Endpoint",
      "type": "bargauge",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "targets": [{
        "expr": "topk(10, sum by (handler) (rate(http_requests_total{job=\"scraping_backend\"}[5m])))",
        "legendFormat": "{{handler}}"
      }],
      "options": { "orientation": "horizontal", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 8,
      "title": "Worker Concurrency",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "targets": [{
        "expr": "flower_worker_number_of_tasks{job=\"celery_workers\"}",
        "legendFormat": "{{worker_name}} — {{task_state}}"
      }]
    }
  ]
}
