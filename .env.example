# Database
POSTGRES_USER=scraping
POSTGRES_PASSWORD=scraping_pass
POSTGRES_DB=scraping_platform
DATABASE_URL=postgresql+asyncpg://scraping:scraping_pass@db:5432/scraping_platform
DATABASE_URL_SYNC=postgresql://scraping:scraping_pass@db:5432/scraping_platform

# Redis / Celery
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# Security
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
ACCESS_TOKEN_EXPIRE_MINUTES=60
ALGORITHM=HS256

# App
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO
API_PREFIX=/api/v1
PROJECT_NAME=Senior Automation Platform

# Scraping
PROXY_LIST_URL=
CAPTCHA_SERVICE_KEY=
MAX_CONCURRENT_SCRAPERS=5
SCRAPE_TIMEOUT_SECONDS=30
MAX_RETRIES=3

# Monitoring
GRAFANA_PASSWORD=admin
PROMETHEUS_MULTIPROC_DIR=/tmp/prometheus_multiproc

# Alerts (Phase 2)
ALERT_WEBHOOK_URL=
PRICE_DROP_THRESHOLD_PCT=5.0
PRICE_SPIKE_THRESHOLD_PCT=20.0
